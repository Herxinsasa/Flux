{
  "name": "flux-app",
  "version": "1.0.1",
  "description": "Flux - AI-powered immersive text editing, analysis, and reading Electron desktop tool",
  "main": "./out/main/index.js",
  "author": "Flux Team",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "icons:build": "node scripts/build-installer-icon.mjs",
    "pack": "npm run icons:build && electron-vite build && electron-builder",
    "pack:win": "npm run icons:build && electron-vite build && electron-builder --win",
    "pack:mac": "npm run icons:build && electron-vite build && electron-builder --mac",
    "package:win": "npm run icons:build && electron-builder --win",
    "package:mac": "npm run icons:build && electron-builder --mac",
    "package:linux": "npm run icons:build && electron-builder --linux",
    "preview": "electron-vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@codemirror/closebrackets": "^0.19.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@mdxeditor/editor": "^3.55.0",
    "@types/markdown-it": "^14.1.2",
    "@uiw/react-codemirror": "^4.25.9",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^1.14.0",
    "markdown-it": "^14.1.1",
    "openai": "^6.35.0",
    "react-virtuoso": "^4.18.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
